# System Configuration
APP_NAME="Enterprise RAG Chatbot"
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1

# Server Bindings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Security & Secrets
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY=94bc99f06df5c68f123f99496aefb834927a4192b0c34e0623a6f199b9cf9509
JWT_REFRESH_SECRET_KEY=e71c99f06df5c68f123f99496aefb834927a4192b0c34e0623a6f199b9cf9508
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# PostgreSQL Configuration
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_rag
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_rag

# Redis Configuration (Caching & Celery broker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Ollama & LLM Configuration
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral:7b

# Gemini Configuration (Optional, required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

EMBEDDING_MODEL=all-MiniLM-L6-v2

# Initial Admin Seeding Configuration
INITIAL_ADMIN_EMAIL=admin@company.com
INITIAL_ADMIN_PASSWORD=AdminSecurePassword123!
INITIAL_ADMIN_FULL_NAME="System Administrator"
INITIAL_ADMIN_DEPARTMENT="IT & Administration"
INITIAL_ADMIN_DEPARTMENT_CODE="IT"

# Storage Settings
UPLOAD_DIR=./data/uploads
VECTOR_STORE_DIR=./data/vector_store
MAX_UPLOAD_SIZE_MB=50

# CORS Origins (Comma-separated list or JSON-parsed list)
# BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8000","https://enterprise-rag-chatbot-llp3ygc4f-mehulllll-s-projects.vercel.app"]
