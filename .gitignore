# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be useful so that coworkers run the exact same version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions.
#pdm.lock

